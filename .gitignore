# -----------------------------------------------
# Android Build Artifacts
# -----------------------------------------------

# Decompiled APK (apktool output) — regenerate with: apktool d love.apk -o love_decompiled
love_decompiled/

# Downloaded prebuilt love-android APK
love.apk

# Unsigned and intermediate APKs
*_unsigned.apk
*_unsigned-aligned-signed.apk
*_unsigned-aligned-signed.apk.idsig

# Signed release APK (distribute separately, not via git)
armadillo_in_fire.apk

# Keystore — NEVER commit this, but back it up somewhere safe offline
# Losing it means you can never update your Play Store listing
*.keystore

# -----------------------------------------------
# Web Build Artifacts
# -----------------------------------------------

# love.js build output folder — regenerate with: node .../love.js/index.js mygame.love output_folder
output_folder/

# Web build zip for itch.io upload
web_build.zip
