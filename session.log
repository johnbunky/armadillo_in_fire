-- FILE: main.lua --
function love.load()
    -- Set window title
    love.window.setTitle("Two Balls - Push Game")
    
    -- Set window size
    love.window.setMode(800, 600)
    
    -- Initialize game state
    gameState = "playing"
    
    -- Create Ball class
    Ball = {}
    Ball.__index = Ball
    
    function Ball:new(x, y, radius, color, isPlayer)
        local ball = {}
        setmetatable(ball, Ball)
        
        ball.x = x or 0
        ball.y = y or 0
        ball.radius = radius or 20
        ball.color = color or {1, 1, 1}  -- white by default
        ball.vx = 0  -- velocity x
        ball.vy = 0  -- velocity y
        ball.isPlayer = isPlayer or false
        
        return ball
    end
    
    function Ball:update(dt)
        -- Apply friction/damping
        local friction = 0.98  -- Adjusted for smoother movement
        if not self.isPlayer then
            self.vx = self.vx * friction
            self.vy = self.vy * friction
            
            -- Stop very small movements
            if math.abs(self.vx) < 5 then self.vx = 0 end
            if math.abs(self.vy) < 5 then self.vy = 0 end
        end
        
        -- Update position based on velocity
        self.x = self.x + self.vx * dt
        self.y = self.y + self.vy * dt
        
        -- Keep ball within screen bounds with bounce dampening
        if self.x - self.radius < 0 then
            self.x = self.radius
            self.vx = -self.vx * 0.3  -- Bounce with energy loss
        elseif self.x + self.radius > love.graphics.getWidth() then
            self.x = love.graphics.getWidth() - self.radius
            self.vx = -self.vx * 0.3
        end
        
        if self.y - self.radius < 0 then
            self.y = self.radius
            self.vy = -self.vy * 0.3
        elseif self.y + self.radius > love.graphics.getHeight() then
            self.y = love.graphics.getHeight() - self.radius
            self.vy = -self.vy * 0.3
        end
    end
    
    function Ball:draw()
        love.graphics.setColor(self.color[1], self.color[2], self.color[3])
        love.graphics.circle("fill", self.x, self.y, self.radius)
        
        -- Draw outline for better visibility
        love.graphics.setColor(0.8, 0.8, 0.8)
        love.graphics.circle("line", self.x, self.y, self.radius)
    end
    
    -- Collision detection between two balls
    function checkCollision(ball1, ball2)
        local dx = ball2.x - ball1.x
        local dy = ball2.y - ball1.y
        local distance = math.sqrt(dx * dx + dy * dy)
        local minDistance = ball1.radius + ball2.radius
        
        return distance < minDistance, dx, dy, distance
    end
    
    -- Resolve collision and apply push physics
    function resolveCollision(ball1, ball2)
        local colliding, dx, dy, distance = checkCollision(ball1, ball2)
        
        if colliding then
            -- Normalize the collision vector
            local nx = dx / distance
            local ny = dy / distance
            
            -- Separate the balls to prevent overlap
            local overlap = (ball1.radius + ball2.radius - distance) / 2
            ball1.x = ball1.x - nx * overlap
            ball1.y = ball1.y - ny * overlap
            ball2.x = ball2.x + nx * overlap
            ball2.y = ball2.y + ny * overlap
            
            -- Calculate relative velocity
            local relativeVelX = ball1.vx - ball2.vx
            local relativeVelY = ball1.vy - ball2.vy
            
            -- Calculate relative velocity along collision normal
            local relativeSpeed = relativeVelX * nx + relativeVelY * ny
            
            -- Only resolve if objects are moving towards each other
            if relativeSpeed < 0 then
                return
            end
            
            -- Apply restitution (bounce factor)
